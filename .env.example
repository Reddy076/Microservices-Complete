# =============================================================
# Docker Compose Environment Variables
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control (add it to .gitignore).
# =============================================================

# --- Database ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=rev_password_manager
MYSQL_USER=root
MYSQL_PASSWORD=rootpassword

# --- Redis ---
REDIS_PASSWORD=RevatureCache@123

# --- JWT ---
JWT_SECRET=your-256-bit-secret-key-here
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# --- Mail (Gmail example) ---
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-gmail-app-password

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:4200

# --- AI / Groq ---
# Get a free key at https://console.groq.com
OPENAI_API_KEY=your-groq-api-key-here
LLM_PROVIDER=OPENAI
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-70b-versatile
